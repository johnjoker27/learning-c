#include <stdio.h>
#include <stdlib.h>

int main()
{
    // ---------------- BASIC POINTER ----------------
    int y_int = 10;  
    char *px;

    px = (char *)&y_int;  
    // Pointer: a variable that stores the address of another variable
    // &y_int means "address of y_int"
    // px now holds the memory address of y_int (cast to char*)

    int a = 5;
    int *pa = &a;
    // pa is a pointer to int
    // it stores the address of variable 'a'

    // ---------------- DEREFERENCING ----------------
    // Dereferencing = accessing the value at the address a pointer holds
    printf("Value of a: %d\n", a);
    printf("Value of a using pointer (*pa): %d\n", *pa);
    // *pa means "value at address stored in pa"

    // ---------------- VOID POINTER ----------------
    // Void pointer: not attached to a specific data type
    void *pv;
    pv = &a;

    // Must cast before dereferencing
    printf("Value using void pointer: %d\n", *(int *)pv);

    // ---------------- NULL POINTER ----------------
    // A pointer that points to nothing
    int *pnull = NULL;
    // Dereferencing (*pnull) would crash the program

    // ---------------- CHAR POINTER EXAMPLE ----------------
    char y = 'q';
    char *px2 = &y;

    printf("&y (address of y): %p\n", (void *)&y);
    printf("&px2 (address of pointer): %p\n", (void *)&px2);
    printf("px2 (stored address): %p\n", (void *)px2);

    // ---------------- INT POINTER DETAILS ----------------
    printf("a: %d\n", a);
    printf("pa (address stored in pointer): %p\n", (void *)pa);
    printf("&a (actual address of a): %p\n", (void *)&a);
    printf("&pa (address of pointer itself): %p\n", (void *)&pa);

    // ---------------- VOID POINTER REUSE ----------------
    pv = &y;
    printf("pv (pointing to y): %p\n", pv);

    pv = &a;
    printf("pv (pointing to a): %p\n", pv);

    // ---------------- POINTER TO POINTER ----------------
    int **ppa = &pa;
    // ppa stores the address of pointer pa

    printf("ppa (address of pa): %p\n", (void *)ppa);
    printf("&ppa (address of pointer-to-pointer): %p\n", (void *)&ppa);
    printf("pa (address of a): %p\n", (void *)pa);

    // Dereferencing levels:
    // *ppa  -> gives pa (address of a)
    // **ppa -> gives value of a
    printf("*ppa (value of pa): %p\n", (void *)*ppa);
    printf("**ppa (value of a): %d\n", **ppa);




// -------- FUNCTION 1: Modify value --------
void changeValue(int *p)
{
    *p = 100;
}

// -------- FUNCTION 2: Swap values --------
void swap(int *a, int *b)
{
    int temp = *a;
    *a = *b;
    *b = temp;
}

// -------- FUNCTION 3: Multiple outputs --------
void calculate(int x, int y, int *sum, int *product)
{
    *sum = x + y;
    *product = x * y;
}

// -------- FUNCTION 4: Pointer to pointer --------
void changePointer(int **pp)
{
    static int newVal = 999;
    *pp = &newVal;
}

// -------- FUNCTION 5: Array using pointer --------
void printArray(int *arr, int size)
{
    for(int i = 0; i < size; i++)
    {
        printf("%d ", *(arr + i));
    }
    printf("\n");
}


    // ---------------- BASIC POINTER ----------------
    int a = 10;
    int *pa = &a;

    printf("a = %d\n", a);
    printf("*pa = %d\n\n", *pa);

    // ---------------- FUNCTION: MODIFY VALUE ----------------
    changeValue(&a);
    printf("After changeValue: %d\n\n", a);

    // ---------------- FUNCTION: SWAP ----------------
    int x = 5, y = 20;
    printf("Before swap: x=%d y=%d\n", x, y);

    swap(&x, &y);
    printf("After swap: x=%d y=%d\n\n", x, y);

    // ---------------- FUNCTION: MULTIPLE RETURN ----------------
    int sum, product;
    calculate(3, 4, &sum, &product);

    printf("Sum = %d, Product = %d\n\n", sum, product);

    // ---------------- VOID POINTER ----------------
    void *pv = &a;
    printf("Void pointer value: %d\n\n", *(int *)pv);

    // ---------------- POINTER TO POINTER ----------------
    int *p = &a;
    printf("Before changePointer: %d\n", *p);

    changePointer(&p);
    printf("After changePointer: %d\n\n", *p);

    // ---------------- ARRAY WITH POINTER ----------------
    int arr[] = {1, 2, 3, 4, 5};
    printf("Array elements: ");
    printArray(arr, 5);

    



    return 0;
}
